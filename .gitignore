# =============================================================
# Node.js — backend/ y web-react/
# =============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
.npm

# =============================================================
# Variables de entorno
# El archivo real (.env) se ignora; el ejemplo (.env.example) SÍ se sube
# =============================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# =============================================================
# React — artefactos generados por `npm run build`
# =============================================================
web-react/build/

# =============================================================
# macOS
# =============================================================
.DS_Store
**/.DS_Store

